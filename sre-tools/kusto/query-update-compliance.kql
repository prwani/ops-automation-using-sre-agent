// query-update-compliance — Missing patches by server
// Parameters: ServerName (optional), ClassificationParam (optional)
let ServerName = "{server_name}";
let ClassificationParam = "{classification}"; // "Critical", "Security Updates", "" for all
Update
| where TimeGenerated >= ago(7d)
| where UpdateState == "Needed"
| where Computer == iff(isempty(ServerName), Computer, ServerName)
| where iff(isempty(ClassificationParam), true, Classification == ClassificationParam)
| summarize 
    MissingPatches = count(),
    CriticalCount = countif(MSRCSeverity == "Critical"),
    SecurityCount = countif(Classification == "Security Updates")
  by Computer, Classification
| order by CriticalCount desc, MissingPatches desc
