// query-security-alerts — Defender for Cloud security alerts
// Parameters: ServerName (optional string), Severity (optional: "High"|"Medium"|"Low"), HoursBack (int)
//
// HOW TO USE THIS QUERY:
//   Option A — Paste into SRE Agent chat directly:
//     "Run this KQL against my Log Analytics workspace: <paste query below>"
//   Option B — Agent uses RunAzCliReadCommands (built-in tool, no custom tool needed):
//     az monitor log-analytics query --workspace f98fca75-7479-45e5-bf0c-87b56a9f9e8c --analytics-query "<this query>" -o json
let ServerName = "{server_name}";  // empty string = all servers
let Severity = "{severity}";       // empty string = all severities
let HoursBack = {hours_back};
SecurityAlert
| where TimeGenerated >= ago(totimespan(strcat(tostring(HoursBack), "h")))
| where AlertSeverity == iff(isempty(Severity), AlertSeverity, Severity)
| where Entities has iff(isempty(ServerName), "", ServerName) or isempty(ServerName)
| project
    TimeGenerated,
    AlertName,
    AlertSeverity,
    Description,
    RemediationSteps,
    Entities,
    ProviderName,
    Status
| order by TimeGenerated desc
| take 100
