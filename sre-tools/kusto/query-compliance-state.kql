// query-compliance-state — Regulatory compliance status from Resource Graph
// Executed against Azure Resource Graph (NOT Log Analytics)
// Parameters: SubscriptionId, Standard (e.g. "CIS Windows Server 2022 Benchmark")
//
// HOW TO USE THIS QUERY:
//   NOTE: This queries Azure Resource Graph, not Log Analytics. Use `az graph query` instead of `az monitor log-analytics query`.
//   Option A — Paste into SRE Agent chat directly:
//     "Run this query against Azure Resource Graph: <paste query below>"
//   Option B — Agent uses RunAzCliReadCommands (built-in tool, no custom tool needed):
//     az graph query -q "<this query>" --subscriptions <subscription_id> -o json
SecurityResources
| where type == "microsoft.security/regulatorycompliancestandards/regulatorycompliancecontrols/regulatorycomplianceassessments"
| where subscriptionId == "{subscription_id}"
| extend standard = tostring(properties.regulatoryComplianceStandardName)
| where standard contains "{compliance_standard}"
| extend 
    controlId = tostring(properties.regulatoryComplianceControlId),
    controlName = tostring(properties.description),
    state = tostring(properties.state),
    passedResources = toint(properties.passedResources),
    failedResources = toint(properties.failedResources),
    skippedResources = toint(properties.skippedResources)
| where state == "Failed"
| summarize
    TotalFailedControls = count(),
    TotalFailedResources = sum(failedResources)
  by controlId, controlName, state, failedResources
| order by failedResources desc
| take 20
